        condition: service_healthy
{{- else}}
      qd-{{$.AppName}}-{{.Type}}:
        condition: service_started
{{- end}}
{{- end}}
{{- end}}
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.{{.AppName}}.rule=Host(`{{.Domain}}`)"
      - "traefik.http.routers.{{.AppName}}.entrypoints=websecure"
      - "traefik.http.routers.{{.AppName}}.tls.certresolver=letsencrypt"
      - "traefik.http.services.{{.AppName}}.loadbalancer.server.port={{.Port}}"
{{- range $key, $val := .Headers}}
      - "traefik.http.middlewares.{{$.AppName}}-headers.headers.customresponseheaders.{{$key}}={{$val}}"
{{- end}}
      - "traefik.http.routers.{{.AppName}}.middlewares={{.AppName}}-headers"
      - "simpledeploy.managed=true"
      - "simpledeploy.app={{.AppName}}"
      - "simpledeploy.repo={{.Repo}}"
      - "simpledeploy.branch={{.Branch}}"
{{- range .Databases}}

  qd-{{$.AppName}}-{{.Type}}:
    image: {{.Image}}
    container_name: qd-{{$.AppName}}-{{.Type}}
    restart: unless-stopped
    networks:
      - simpledeploy
{{- if .Env}}
    environment:
{{- range $key, $val := .Env}}
      {{$key}}: {{$val}}
{{- end}}
{{- end}}
    volumes:
      - {{.VolumeName}}:{{.Volume}}
{{- if .HealthCheck}}
    healthcheck:
      test: [{{- range $i, $t := .HealthCheck.Test}}{{if $i}}, {{end}}"{{$t}}"{{- end}}]
      interval: {{.HealthCheck.Interval}}
      timeout: {{.HealthCheck.Timeout}}
      retries: {{.HealthCheck.Retries}}
{{- end}}
{{- end}}

networks:
  simpledeploy:
    external: true
{{- if .Databases}}

volumes:
{{- range .Databases}}
